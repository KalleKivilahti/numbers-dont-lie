DATABASE_URL="file:./dev.db"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# OAuth (optional for local dev) — Google + GitHub
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# AI insights (optional — mock insights used if unset)
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# Email — omit SMTP_* for dev (terminal only). Gmail: App Password for SMTP_PASSWORD; leave EMAIL_FROM empty or same as SMTP_USER.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_SECURE="false"
EMAIL_FROM=""
