# Copy to .env and fill in. Never commit .env (see .gitignore).
# For production (e.g. Netlify), set these in the host UI — not in the repo.

DATABASE_URL="file:./dev.db"
NEXTAUTH_URL="http://localhost:3000"
# Required: run `openssl rand -base64 32` and paste the result (no quotes needed if no spaces).
NEXTAUTH_SECRET=

# OAuth (optional) — Google + GitHub
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# AI insights (optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Email — omit SMTP_* for dev (links only in server log). For Gmail use an App Password.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_SECURE=false
EMAIL_FROM=
